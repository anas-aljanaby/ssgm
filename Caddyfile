ssgm.app, www.ssgm.app {
    # API — strip the /api prefix, forward to the Hono container
    handle_path /api/* {
        reverse_proxy api:3000
    }

    # Everything else — the React SPA (nginx container)
    handle {
        reverse_proxy web:80
    }
}

# Full-pages app — separate compose project, reached via its host port 81
full.ssgm.app {
    reverse_proxy host.docker.internal:81
}
