# Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe for client use, but we keep it server-side too)
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — has full DB access, NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pooled connection — used by the app at runtime (Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-region.pooler.supabase.com:6543/postgres

# Direct connection — used by drizzle-kit for migrations (Session mode, port 5432)
# Found in Project Settings → Database → Connection string → Session mode
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

PORT=3000

# Comma-separated browser origins allowed for CORS (must match the URL in the address bar exactly).
# Local dev: include localhost and, if you use Vite's network URL, your LAN origin too, e.g.
# WEB_ORIGIN=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.101:8000
# Production (Render): set this in the Render dashboard to your Vercel URL plus localhost for dev.
WEB_ORIGIN=http://localhost:8000
