# Supabase (required for auth)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API server URL (defaults to http://localhost:3000).
# Use localhost during local dev (with `npm run dev:api`). Pointing at Render from the browser
# requires WEB_ORIGIN on the API to include your exact frontend origin (and cold starts can fail).
VITE_API_URL=http://localhost:3000
