{
  "name": "gms-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=@gms/web",
    "build:web": "npm run build --workspace=@gms/web",
    "dev:api": "npm run dev --workspace=@gms/api",
    "build:api": "npm run build --workspace=@gms/api"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "jspdf": "4.2.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "drizzle-kit": "^0.18.1"
  }
}
